APP_NAME="EIAAW Social Media Team"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://smt.eiaawsolutions.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# ─── Database (Railway-injected via DATABASE_URL or split vars) ─────
# Railway's Postgres service exposes these via service references:
#   ${{Postgres.PGHOST}} / .PGPORT / .PGDATABASE / .PGUSER / .PGPASSWORD
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ─── Cache / Session / Queue (Redis on Railway internal network) ────
SESSION_DRIVER=redis
CACHE_STORE=redis
CACHE_PREFIX=eiaaw_smt
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_USERNAME=default

# ─── Mail ───────────────────────────────────────────────────────────
# Product transactional mail goes through Mailgun (welcome, trial-ending).
# Security alerts are pinned to Resend in config/security.php so they
# don't share a transport with high-volume marketing/product email.
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS="noreply@eiaawsolutions.com"
MAIL_FROM_NAME="${APP_NAME}"
MAILGUN_DOMAIN=mg.eiaawsolutions.com
MAILGUN_SECRET=secret://eiaaw-smt-prod/prod/MAILGUN_SECRET
RESEND_KEY=secret://eiaaw-smt-prod/prod/RESEND_KEY

# ─── Security alerts ────────────────────────────────────────────────
# HIGH-severity prompt-injection / abuse events email this address via
# Resend. See config/security.php for thresholds and throttling.
SECURITY_ALERT_RECIPIENT=eiaawsolutions@gmail.com
SECURITY_ALERT_FROM=security@eiaawsolutions.com
SECURITY_ALERT_FROM_NAME="EIAAW Security"
INJECTION_DETECTOR_ENABLED=true
# Set to false for the first 48h of production to baseline false-positive
# rate without blocking real traffic. Detector still logs to security_events.
INJECTION_DETECTOR_ENFORCE=true

# ─── Infisical bootstrap (the only raw secrets that live here) ──────
INFISICAL_RESOLVER_ENABLED=true
INFISICAL_SITE_URL=https://app.infisical.com
INFISICAL_APP_CLIENT_ID=
INFISICAL_APP_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=prod

# ─── AI providers (resolved from Infisical at boot) ─────────────────
ANTHROPIC_API_KEY=secret://eiaaw-smt-prod/prod/ANTHROPIC_API_KEY
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5-20251001

FAL_API_KEY=secret://eiaaw-smt-prod/prod/FAL_API_KEY
# Nano Banana (Gemini 2.5 Flash Image) — best prompt adherence, ~$0.039/image.
# Uses aspect_ratio (not flux image_size); FalAiClient maps the size per-model.
FAL_IMAGE_MODEL=fal-ai/nano-banana
# Video — Google Veo 3 Fast. i2v when a Designer still exists (keyframe), t2v
# otherwise. $0.10/sec audio-off, $0.15/sec audio-on. Base call accepts only
# 4/6/8s and 16:9/9:16 (NO 1:1). Roll back to fal-ai/wan-25-preview/* if needed.
FAL_VIDEO_MODEL_IMAGE=fal-ai/veo3/fast/image-to-video
FAL_VIDEO_MODEL_TEXT=fal-ai/veo3/fast
# Veo 3.1 extend-video — appends +7s/step to build clips longer than 8s
# (15s = 8s base + 1 extend). $0.20/sec off, $0.40/sec on. Native-audio path only.
FAL_VIDEO_MODEL_EXTEND=fal-ai/veo3.1/extend-video
# Veo native audio: model speaks the distilled voiceover + scores the clip
# itself; when true we SKIP the FFmpeg voiceover/music composer. Set false to
# mute Veo and use the legacy Kokoro voiceover+music+subtitles brand composer.
FAL_VIDEO_NATIVE_AUDIO=true
# Target clip length in seconds. Base snaps to 4/6/8; >8 is built via +7s
# extend steps. Capped at 22s (8 base + 2 extends) in VideoAgent. 15 = 8 + 7.
FAL_VIDEO_DURATION_SECONDS=15
# Per-workspace daily video budget (USD). A 15s audio-on clip ≈ $4, so $15 ≈
# 3-4 clips/day. Raise alongside FAL_VIDEO_DURATION_SECONDS for longer formats.
FAL_VIDEO_DAILY_CAP_USD=15

# ─── Publishing ─────────────────────────────────────────────────────
# Per-workspace isolation (since 2026-05-27): each Workspace stores its own
# Blotato API key handle in workspaces.blotato_api_key_handle (referenced as
# secret://eiaaw-smt-prod/prod/BLOTATO_API_KEY_WS_{id}). The BLOTATO_API_KEY
# below is the HQ workspace fallback — used ONLY by legacy/bootstrap paths
# (e.g. `php artisan platforms:sync --brand=…` with no per-workspace handle
# set, or BlotatoClient::fromConfig() callers that pre-date the refactor).
# Customer-facing code paths MUST use BlotatoClient::forWorkspace() so a
# customer's connections, publishes, and metrics route through THEIR
# Blotato account — never through HQ's.
BLOTATO_API_KEY=secret://eiaaw-smt-prod/prod/BLOTATO_API_KEY
BLOTATO_BASE_URL=https://backend.blotato.com

# ─── Cloudflare R2 ──────────────────────────────────────────────────
R2_ACCESS_KEY_ID=secret://eiaaw-smt-prod/prod/R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=secret://eiaaw-smt-prod/prod/R2_SECRET_ACCESS_KEY
R2_BUCKET=eiaaw-smt-prod
R2_ENDPOINT=
R2_PUBLIC_URL=

# ─── Billing ────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=secret://eiaaw-smt-prod/prod/STRIPE_SECRET
STRIPE_WEBHOOK_SECRET=secret://eiaaw-smt-prod/prod/STRIPE_WEBHOOK_SECRET

BILLPLZ_API_KEY=secret://eiaaw-smt-prod/prod/BILLPLZ_API_KEY
BILLPLZ_X_SIGNATURE=secret://eiaaw-smt-prod/prod/BILLPLZ_X_SIGNATURE
BILLPLZ_COLLECTION_ID=
BILLPLZ_SANDBOX=false

VITE_APP_NAME="${APP_NAME}"

# ─── Security headers ───────────────────────────────────────────────
# CSP enforce flag — defaults to false (header is sent as
# Content-Security-Policy-Report-Only). Set to true ONLY after observing
# `storage/logs/csp-*.log` is clean for ~1 week on production. The flip
# is one env var; no code change needed.
CSP_ENFORCE=false
