APP_NAME="EIAAW Social Media Team"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://smt.eiaawsolutions.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# ─── Database (Railway-injected via DATABASE_URL or split vars) ─────
# Railway's Postgres service exposes these via service references:
#   ${{Postgres.PGHOST}} / .PGPORT / .PGDATABASE / .PGUSER / .PGPASSWORD
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ─── Cache / Session / Queue (Redis on Railway internal network) ────
SESSION_DRIVER=redis
CACHE_STORE=redis
CACHE_PREFIX=eiaaw_smt
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_USERNAME=default

# ─── Mail ───────────────────────────────────────────────────────────
# DEFAULT transport is Resend. This is deliberate: the credential-bearing
# welcome email and the HQ setup-request notification ride the DEFAULT
# mailer, and a default of `log` or a half-wired `mailgun` silently dropped
# them in the worker (the customer paid but never got their login). Resend
# is the transport whose deliverability we actually maintain and guard
# (config/resend.php + config/secrets.php resolve both key paths). Keep the
# default here so the reliable path is the default, not the exception.
#   Override per-environment only with a transport you've verified can
#   deliver — never leave this as `log` in any env that serves real signups.
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@eiaawsolutions.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=secret://eiaaw-smt-prod/prod/RESEND_KEY
# Mailgun retained as an available fallback transport (not the default).
# Leave the handles populated so MAIL_MAILER=mailgun is a one-line switch.
MAILGUN_DOMAIN=mg.eiaawsolutions.com
MAILGUN_SECRET=secret://eiaaw-smt-prod/prod/MAILGUN_SECRET

# ─── Security alerts ────────────────────────────────────────────────
# HIGH-severity prompt-injection / abuse events email this address via
# Resend. See config/security.php for thresholds and throttling.
SECURITY_ALERT_RECIPIENT=eiaawsolutions@gmail.com
SECURITY_ALERT_FROM=security@eiaawsolutions.com
SECURITY_ALERT_FROM_NAME="EIAAW Security"
INJECTION_DETECTOR_ENABLED=true
# Set to false for the first 48h of production to baseline false-positive
# rate without blocking real traffic. Detector still logs to security_events.
INJECTION_DETECTOR_ENFORCE=true

# ─── Infisical bootstrap (the only raw secrets that live here) ──────
INFISICAL_RESOLVER_ENABLED=true
INFISICAL_SITE_URL=https://app.infisical.com
INFISICAL_APP_CLIENT_ID=
INFISICAL_APP_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=prod

# ─── AI providers (resolved from Infisical at boot) ─────────────────
ANTHROPIC_API_KEY=secret://eiaaw-smt-prod/prod/ANTHROPIC_API_KEY
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5-20251001

FAL_API_KEY=secret://eiaaw-smt-prod/prod/FAL_API_KEY
# Nano Banana (Gemini 2.5 Flash Image) — best prompt adherence, ~$0.039/image.
# Uses aspect_ratio (not flux image_size); FalAiClient maps the size per-model.
FAL_IMAGE_MODEL=fal-ai/nano-banana
# Video — ByteDance Seedance 2.0 Fast (default). i2v when a Designer still
# exists (keyframe), t2v otherwise. ~$0.2419/sec at 720p, native audio bundled
# (no surcharge); a 15s clip ≈ $3.63, rendered in ONE call (no extend). duration
# is a stringified int "4".."15"; aspect 9:16/16:9. Roll back to Veo with
# fal-ai/veo3/fast/* or to Wan with fal-ai/wan-25-preview/* .
FAL_VIDEO_MODEL_IMAGE=bytedance/seedance-2.0/fast/image-to-video
FAL_VIDEO_MODEL_TEXT=bytedance/seedance-2.0/fast/text-to-video
# Veo 3.1 extend-video — appends +7s/step for a VEO ROLLBACK to build clips
# longer than Veo's 8s cap. DORMANT under Seedance (single 15s call). Keep set so
# a Veo rollback works. $0.20/sec off, $0.40/sec on.
FAL_VIDEO_MODEL_EXTEND=fal-ai/veo3.1/extend-video
# Native audio: model speaks the distilled voiceover + scores the clip itself
# (Seedance and Veo); when true we SKIP the FFmpeg voiceover/music composer. Set
# false only under a Wan-style model to use the legacy Kokoro voiceover+music+subs.
FAL_VIDEO_NATIVE_AUDIO=true
# Target clip length in seconds. Under Seedance this is a single 15s call. Under
# a Veo rollback the base snaps to 4/6/8 and >8 uses +7s extend steps (capped at
# 22s in VideoAgent).
FAL_VIDEO_DURATION_SECONDS=15
# NOTE: there is NO per-day USD FAL budget env var. Image/video generation is
# bound ONLY by the monthly volume caps in config/billing.php (the customer
# self-paces within the month). The old FAL_DAILY_CAP_USD / FAL_VIDEO_DAILY_CAP_USD
# were removed 2026-06-01 — do not reintroduce. See [[no-daily-fal-cap]].

# ─── Strategy intelligence (competitor + market/trend feeds) ────────
# These power the Strategist's data-driven planning. When absent the
# per-brand prompt blocks self-suppress and the Strategist plans on
# brand-voice alone — the content-recycling root cause. Firecrawl is the
# ONE external key: it drives BOTH LinkedIn competitor-ad scraping and
# market/trend web search. Meta competitor ads reuse each brand's existing
# Facebook/Instagram OAuth token (no separate key). Growth intel needs no
# external fetch (runs off Metricool metrics already wired above).
FIRECRAWL_API_KEY=secret://eiaaw-smt-prod/prod/FIRECRAWL_API_KEY
# Market/trend intel is OFF by default — flip to true to activate the
# MarketIntelAgent fetch (requires FIRECRAWL_API_KEY). Competitor + growth
# intel default on but still need per-brand config (see intel:seed-config).
MARKET_INTEL_ENABLED=true
COMPETITOR_INTEL_ENABLED=true
GROWTH_STRATEGY_ENABLED=true

# ─── Publishing ─────────────────────────────────────────────────────
# Per-workspace isolation (since 2026-05-27): each Workspace stores its own
# Blotato API key handle in workspaces.blotato_api_key_handle (referenced as
# secret://eiaaw-smt-prod/prod/BLOTATO_API_KEY_WS_{id}). The BLOTATO_API_KEY
# below is the HQ workspace fallback — used ONLY by legacy/bootstrap paths
# (e.g. `php artisan platforms:sync --brand=…` with no per-workspace handle
# set, or BlotatoClient::fromConfig() callers that pre-date the refactor).
# Customer-facing code paths MUST use BlotatoClient::forWorkspace() so a
# customer's connections, publishes, and metrics route through THEIR
# Blotato account — never through HQ's.
BLOTATO_API_KEY=secret://eiaaw-smt-prod/prod/BLOTATO_API_KEY
BLOTATO_BASE_URL=https://backend.blotato.com

# ─── Cloudflare R2 (durable store for brand assets — REQUIRED in prod) ──
# When R2_BUCKET is set, brand-asset uploads go to R2; otherwise they fall
# back to the local `public` disk, which is EPHEMERAL on Railway (wiped each
# redeploy) — files vanish and previews break. Verify the whole chain with
# `php artisan storage:r2-check`. Credentials are Infisical handles; the two
# non-secret values below are set directly (they are not secrets).
R2_ACCESS_KEY_ID=secret://eiaaw-smt-prod/prod/R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=secret://eiaaw-smt-prod/prod/R2_SECRET_ACCESS_KEY
R2_BUCKET=eiaaw-smt-prod
# S3 API endpoint: https://<cloudflare-account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
# PUBLIC base url for serving objects. Use a custom domain in prod
# (e.g. https://assets.eiaawsolutions.com); the *.r2.dev URL is rate-limited
# and dev-only per Cloudflare.
R2_PUBLIC_URL=

# ─── Billing ────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=secret://eiaaw-smt-prod/prod/STRIPE_SECRET
STRIPE_WEBHOOK_SECRET=secret://eiaaw-smt-prod/prod/STRIPE_WEBHOOK_SECRET

BILLPLZ_API_KEY=secret://eiaaw-smt-prod/prod/BILLPLZ_API_KEY
BILLPLZ_X_SIGNATURE=secret://eiaaw-smt-prod/prod/BILLPLZ_X_SIGNATURE
BILLPLZ_COLLECTION_ID=
BILLPLZ_SANDBOX=false

VITE_APP_NAME="${APP_NAME}"

# ─── Security headers ───────────────────────────────────────────────
# CSP enforce flag — defaults to false (header is sent as
# Content-Security-Policy-Report-Only). Set to true ONLY after observing
# `storage/logs/csp-*.log` is clean for ~1 week on production. The flip
# is one env var; no code change needed.
CSP_ENFORCE=false
